{
  "permissions": {
    "allow": [
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(grep*)",
      "Bash(find . *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Reload the extension in Chrome: chrome://extensions/ \\u2192 Reload (\\u21ba)\"}'"
          }
        ]
      }
    ]
  }
}
