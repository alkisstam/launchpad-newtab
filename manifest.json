{
  "manifest_version": 3,
  "name": "Launchpad New Tab",
  "version": "1.0",
  "description": "A beautiful new tab with time, weather, top sites, and recent downloads.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "topSites",
    "downloads",
    "geolocation",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://suggestqueries.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
