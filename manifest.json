{
  "manifest_version": 3,
  "name": "Launchpad New Tab",
  "version": "1.05",
  "description": "Material Design 3 new tab with clock, weather, search suggestions, top sites, favorites, downloads, quick notes, to-do list, and Pomodoro timer.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "topSites",
    "downloads",
    "geolocation",
    "storage"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://suggestqueries.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
